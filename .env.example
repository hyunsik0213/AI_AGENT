# host port bindings (if 8000 is occupied, change AGENT_HOST_PORT to 8002 etc.)
AGENT_HOST_PORT=8000
MOCK_HOST_PORT=8001

# agent token used against mock spring API
AGENT_TOKEN=agent_admin_token

# intent parsing mode: rule or gemini
INTENT_MODE=rule

# when INTENT_MODE=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
